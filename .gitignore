# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE and editor settings
.vscode/
.idea/
*.iml

# Operating system files
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp

# SQLite runtime and temp files
db/*.db-wal
db/*.db-shm
db/*.db-journal

# Generated report output
python/reports_jrxml/out/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local Git metadata should never be archived inside the repository folder
.git/
